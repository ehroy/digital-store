# ─── Server ───────────────────────────────────────────────────
PORT=8080
DB_PATH=./digistore.db

# ─── Admin credentials ────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti_password_ini

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=ganti-dengan-random-string-panjang-minimal-32char

# ─── CORS / Frontend ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://yourdomain.com

# ─── SMTP (Gmail contoh) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=DigiStore <noreply@yourdomain.com>
# Gunakan App Password jika pakai Gmail (bukan password biasa)
# https://myaccount.google.com/apppasswords
